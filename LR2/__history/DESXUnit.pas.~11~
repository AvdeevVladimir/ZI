nit DESXUnit;

interface

uses
  SysUtils, Classes, Dialogs;

type
  TByteArray = array of Byte;

  TDESX = class
  private
    // Таблицы перестановок для DES
    const
      IP: array[0..63] of Byte = (
        58, 50, 42, 34, 26, 18, 10, 2, 60, 52, 44, 36, 28, 20, 12, 4,
        62, 54, 46, 38, 30, 22, 14, 6, 64, 56, 48, 40, 32, 24, 16, 8,
        57, 49, 41, 33, 25, 17, 9, 1, 59, 51, 43, 35, 27, 19, 11, 3,
        61, 53, 45, 37, 29, 21, 13, 5, 63, 55, 47, 39, 31, 23, 15, 7
      );

      FP: array[0..63] of Byte = (
        40, 8, 48, 16, 56, 24, 64, 32, 39, 7, 47, 15, 55, 23, 63, 31,
        38, 6, 46, 14, 54, 22, 62, 30, 37, 5, 45, 13, 53, 21, 61, 29,
        36, 4, 44, 12, 52, 20, 60, 28, 35, 3, 43, 11, 51, 19, 59, 27,
        34, 2, 42, 10, 50, 18, 58, 26, 33, 1, 41, 9, 49, 17, 57, 25
      );

  private
    FKey1: array[0..7] of Byte;  // Основной ключ DES
    FKey2: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)
    FKey3: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)

    function InitialPermutation(const Data: array of Byte): TByteArray;
    function FinalPermutation(const Data: array of Byte): TByteArray;

  public
    constructor Create;
    procedure SetKeys(const Key1, Key2, Key3: array of Byte);
    function EncryptString(const Text: string): string;
    function DecryptString(const EncryptedText: string): string;
    function EncryptFile(const InputFile, OutputFile: string): Boolean;
    function DecryptFile(const InputFile, OutputFile: string): Boolean;
  end;

implementation

{ TDESX }

constructor TDESX.Create;
begin
  inherited;
  FillChar(FKey1, 8, 0);
  FillChar(FKey2, 8, 0);
  FillChar(FKey3, 8, 0);
end;

procedure TDESX.SetKeys(const Key1, Key2, Key3: array of Byte);
begin
  Move(Key1[0], FKey1[0], 8);
  Move(Key2[0], FKey2[0], 8);
  Move(Key3[0], FKey3[0], 8);
end;

// Начальная перестановка IP
function TDESX.InitialPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);

  for i := 0 to 63 do
  begin
    j := IP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

// Конечная перестановка FP
function TDESX.FinalPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);

  for i := 0 to 63 do
  begin
    j := FP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.EncryptString(const Text: string): string;
var
  Bytes, TempBytes: TBytes;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  PermutedBlock: TByteArray;
begin
  try
    Result := '';

    // 1. Преобразуем строку в UTF-8 байты
    Bytes := TEncoding.UTF8.GetBytes(Text);

    // 2. Добавляем паддинг (PKCS7) для кратности 8 байт
    Padding := 8 - (Length(Bytes) mod 8);
    if Padding = 8 then Padding := 0;

    if Padding > 0 then
    begin
      SetLength(TempBytes, Length(Bytes) + Padding);
      Move(Bytes[0], TempBytes[0], Length(Bytes));
      for i := 0 to Padding - 1 do
        TempBytes[Length(Bytes) + i] := Padding;
      Bytes := TempBytes;
    end;

    // 3. Обрабатываем блоки
    BlockCount := Length(Bytes) div 8;

    for i := 0 to BlockCount - 1 do
    begin
      Move(Bytes[i * 8], Block[0], 8);

      // Начальная перестановка
      PermutedBlock := InitialPermutation(Block);

      // Простое XOR с ключами
      for j := 0 to 7 do
      begin
        PermutedBlock[j] := PermutedBlock[j] xor FKey1[j];
        PermutedBlock[j] := PermutedBlock[j] xor FKey2[j];
        PermutedBlock[j] := PermutedBlock[j] xor FKey3[j];
      end;

      // Конечная перестановка
      PermutedBlock := FinalPermutation(PermutedBlock);

      Move(PermutedBlock[0], Bytes[i * 8], 8);
    end;

    // 4. В HEX с пробелами
    for i := 0 to Length(Bytes) - 1 do
    begin
      Result := Result + IntToHex(Bytes[i], 2);
      if (i + 1) mod 4 = 0 then
        Result := Result + ' ';
      if (i + 1) mod 16 = 0 then
        Result := Result + #13#10;
    end;

  except
    on E: Exception do
      Result := 'Error: ' + E.Message;
  end;
end;

function TDESX.DecryptString(const EncryptedText: string): string;
var
  Bytes, DecryptedBytes: TBytes;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  PermutedBlock: TByteArray;
  HexStr: string;
begin
  try
    Result := '';

    // 1. Убираем пробелы
    HexStr := '';
    for i := 1 to Length(EncryptedText) do
    begin
      if EncryptedText[i] in ['0'..'9', 'A'..'F', 'a'..'f'] then
        HexStr := HexStr + EncryptedText[i];
    end;

    if HexStr = '' then Exit;

    // 2. HEX в байты
    SetLength(Bytes, Length(HexStr) div 2);
    for i := 0 to (Length(HexStr) div 2) - 1 do
      Bytes[i] := StrToInt('$' + Copy(HexStr, i*2 + 1, 2));

    // 3. Обрабатываем блоки
    BlockCount := Length(Bytes) div 8;
    SetLength(DecryptedBytes, Length(Bytes));

    for i := 0 to BlockCount - 1 do
    begin
      Move(Bytes[i * 8], Block[0], 8);

      // Начальная перестановка
      PermutedBlock := InitialPermutation(Block);

      // Обратное XOR с ключами
      for j := 0 to 7 do
      begin
        PermutedBlock[j] := PermutedBlock[j] xor FKey1[j];
        PermutedBlock[j] := PermutedBlock[j] xor FKey2[j];
        PermutedBlock[j] := PermutedBlock[j] xor FKey3[j];
      end;

      // Конечная перестановка
      PermutedBlock := FinalPermutation(PermutedBlock);

      Move(PermutedBlock[0], DecryptedBytes[i * 8], 8);
    end;

    // 4. Убираем паддинг
    if Length(DecryptedBytes) > 0 then
    begin
      Padding := DecryptedBytes[Length(DecryptedBytes) - 1];
      if (Padding > 0) and (Padding <= 8) then
        SetLength(DecryptedBytes, Length(DecryptedBytes) - Padding);
    end;

    // 5. Преобразуем байты обратно в текст
    if Length(DecryptedBytes) > 0 then
      Result := TEncoding.UTF8.GetString(DecryptedBytes);

  except
    on E: Exception do
      Result := '';
  end;
end;

function TDESX.EncryptFile(const InputFile, OutputFile: string): Boolean;
var
  SL: TStringList;
begin
  Result := False;
  try
    SL := TStringList.Create;
    try
      SL.LoadFromFile(InputFile);
      SL.Text := EncryptString(SL.Text);
      SL.SaveToFile(OutputFile);
      Result := True;
    finally
      SL.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

function TDESX.DecryptFile(const InputFile, OutputFile: string): Boolean;
var
  SL: TStringList;
begin
  Result := False;
  try
    SL := TStringList.Create;
    try
      SL.LoadFromFile(InputFile);
      SL.Text := DecryptString(SL.Text);
      SL.SaveToFile(OutputFile);
      Result := True;
    finally
      SL.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

end.
