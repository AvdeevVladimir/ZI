      );

      SHIFT: array[0..15] of Byte = (
        1,1,2,2,2,2,2,2,1,2,2,2,2,2,2,1
      );

      S: array[0..7, 0..3, 0..15] of Byte = (
        // S1
        ((14,4,13,1,2,15,11,8,3,10,6,12,5,9,0,7),
         (0,15,7,4,14,2,13,1,10,6,12,11,9,5,3,8),
         (4,1,14,8,13,6,2,11,15,12,9,7,3,10,5,0),
         (15,12,8,2,4,9,1,7,5,11,3,14,10,0,6,13)),
        // S2
        ((15,1,8,14,6,11,3,4,9,7,2,13,12,0,5,10),
         (3,13,4,7,15,2,8,14,12,0,1,10,6,9,11,5),
         (0,14,7,11,10,4,13,1,5,8,12,6,9,3,2,15),
         (13,8,10,1,3,15,4,2,11,6,7,12,0,5,14,9)),
        // S3
        ((10,0,9,14,6,3,15,5,1,13,12,7,11,4,2,8),
         (13,7,0,9,3,4,6,10,2,8,5,14,12,11,15,1),
         (13,6,4,9,8,15,3,0,11,1,2,12,5,10,14,7),
         (1,10,13,0,6,9,8,7,4,15,14,3,11,5,2,12)),
        // S4
        ((7,13,14,3,0,6,9,10,1,2,8,5,11,12,4,15),
         (13,8,11,5,6,15,0,3,4,7,2,12,1,10,14,9),
         (10,6,9,0,12,11,7,13,15,1,3,14,5,2,8,4),
         (3,15,0,6,10,1,13,8,9,4,5,11,12,7,2,14)),
        // S5
        ((2,12,4,1,7,10,11,6,8,5,3,15,13,0,14,9),
         (14,11,2,12,4,7,13,1,5,0,15,10,3,9,8,6),
         (4,2,1,11,10,13,7,8,15,9,12,5,6,3,0,14),
         (11,8,12,7,1,14,2,13,6,15,0,9,10,4,5,3)),
        // S6
        ((12,1,10,15,9,2,6,8,0,13,3,4,14,7,5,11),
         (10,15,4,2,7,12,9,5,6,1,13,14,0,11,3,8),
         (9,14,15,5,2,8,12,3,7,0,4,10,1,13,11,6),
         (4,3,2,12,9,5,15,10,11,14,1,7,6,0,8,13)),
        // S7
        ((4,11,2,14,15,0,8,13,3,12,9,7,5,10,6,1),
         (13,0,11,7,4,9,1,10,14,3,5,12,2,15,8,6),
         (1,4,11,13,12,3,7,14,10,15,6,8,0,5,9,2),
         (6,11,13,8,1,4,10,7,9,5,0,15,14,2,3,12)),
        // S8
        ((13,2,8,4,6,15,11,1,10,9,3,14,5,0,12,7),
         (1,15,13,8,10,3,7,4,12,5,6,11,0,14,9,2),
         (7,11,4,1,9,12,14,2,0,6,10,13,15,3,5,8),
         (2,1,14,7,4,10,8,13,15,12,9,0,3,5,6,11))
      );

  private
    procedure GenerateSubKeys;
    function Permute(const Data: TByteArray; const Table: array of Byte;
                     InputSize, OutputSize: Integer): TByteArray;
    function XORBytes(const A, B: TByteArray): TByteArray;
    function Feistel(const R: TByteArray; const Key: array of Byte): TByteArray;

  public
    constructor Create(const Key1, Key2, Key3: array of Byte);
    function EncryptBlock(const Data: array of Byte): TByteArray;
    function DecryptBlock(const Data: array of Byte): TByteArray;
    procedure EncryptFile(const InputFile, OutputFile: string);
    procedure DecryptFile(const InputFile, OutputFile: string);
  end;

implementation

{ TDESX }

constructor TDESX.Create(const Key1, Key2, Key3: array of Byte);
begin
  inherited Create;
  Move(Key1[0], FKey1[0], Min(8, Length(Key1)));
  Move(Key2[0], FKey2[0], Min(8, Length(Key2)));
  Move(Key3[0], FKey3[0], Min(8, Length(Key3)));
  GenerateSubKeys;
end;

procedure TDESX.GenerateSubKeys;
var
  C, D: array[0..27] of Byte;
  Temp, Combined: array[0..55] of Byte;
  i, Round, ShiftVal: Integer;
begin
  // Применяем PC1
  for i := 0 to 55 do
    Temp[i] := (FKey1[(PC1[i] - 1) div 8] shr (7 - ((PC1[i] - 1) mod 8))) and 1;

  // Разделяем на C и D
  Move(Temp[0], C[0], 28);
  Move(Temp[28], D[0], 28);

  // Генерируем 16 подключей
  for Round := 0 to 15 do
  begin
    FillChar(FSubKeys[Round], 6, 0);

    // Циклический сдвиг влево
    ShiftVal := SHIFT[Round];

    // Сдвиг C
    for i := 0 to 27 - ShiftVal do
      C[i] := C[i + ShiftVal];
    for i := 28 - ShiftVal to 27 do
      C[i] := C[i - (28 - ShiftVal)];

    // Сдвиг D
    for i := 0 to 27 - ShiftVal do
      D[i] := D[i + ShiftVal];
    for i := 28 - ShiftVal to 27 do
      D[i] := D[i - (28 - ShiftVal)];

    // Объединяем
    Move(C[0], Combined[0], 28);
    Move(D[0], Combined[28], 28);

    // Применяем PC2
    for i := 0 to 47 do
    begin
      if Combined[PC2[i] - 1] = 1 then
        FSubKeys[Round][i div 8] := FSubKeys[Round][i div 8] or
                                     (1 shl (7 - (i mod 8)));
    end;
  end;
end;

function TDESX.Permute(const Data: TByteArray; const Table: array of Byte;
                       InputSize, OutputSize: Integer): TByteArray;
var
  i: Integer;
  BitArray: array of Byte;
begin
  SetLength(BitArray, InputSize);
  SetLength(Result, (OutputSize + 7) div 8);
  FillChar(Result[0], Length(Result), 0);

  // Преобразуем байты в биты
  for i := 0 to InputSize - 1 do
    BitArray[i] := (Data[i div 8] shr (7 - (i mod 8))) and 1;

  // Применяем перестановку
  for i := 0 to OutputSize - 1 do
  begin
    if BitArray[Table[i] - 1] = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.XORBytes(const A, B: TByteArray): TByteArray;
var
  i: Integer;
begin
  SetLength(Result, Length(A));
  for i := 0 to High(A) do
    Result[i] := A[i] xor B[i];
end;

function TDESX.Feistel(const R: TByteArray; const Key: array of Byte): TByteArray;
var
  ExpandedR, XorResult: TByteArray;
  SBoxInput: array[0..47] of Byte;
  SBoxOutput: array[0..31] of Byte;
  i, j, Row, Col: Integer;
  Temp: Byte;
begin
  // Расширение
  ExpandedR := Permute(R, E, 32, 48);

  // XOR с ключом
  SetLength(XorResult, 6);
  for i := 0 to 5 do
    XorResult[i] := ExpandedR[i] xor Key[i];

  // Преобразуем в биты
  for i := 0 to 47 do
    SBoxInput[i] := (XorResult[i div 8] shr (7 - (i mod 8))) and 1;

  // S-блоки
  for i := 0 to 7 do
  begin
    Row := (SBoxInput[i * 6] shl 1) or SBoxInput[i * 6 + 5];
    Col := (SBoxInput[i * 6 + 1] shl 3) or (SBoxInput[i * 6 + 2] shl 2) or
           (SBoxInput[i * 6 + 3] shl 1) or SBoxInput[i * 6 + 4];
    Temp := S[i, Row, Col];

    for j := 0 to 3 do
      SBoxOutput[i * 4 + j] := (Temp shr (3 - j)) and 1;
  end;

  // Перестановка P
  SetLength(Result, 4);
  for i := 0 to 31 do
  begin
    if SBoxOutput[P[i] - 1] = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.EncryptBlock(const Data: array of Byte): TByteArray;
var
  Block: TByteArray;
  L, R, Temp: TByteArray;
  Round: Integer;
begin
  SetLength(Block, 8);
  Move(Data[0], Block[0], Min(8, Length(Data)));

  // DESX: XOR с K2
  Block := XORBytes(Block, FKey2);

  // Начальная перестановка
  Block := Permute(Block, IP, 64, 64);

  // Разделение
  SetLength(L, 4);
  SetLength(R, 4);
  Move(Block[0], L[0], 4);
  Move(Block[4], R[0], 4);

  // 16 раундов
  for Round := 0 to 15 do
  begin
    Temp := L;
    L := R;
    R := XORBytes(Temp, Feistel(R, FSubKeys[Round]));
  end;

  // Объединение
  SetLength(Block, 8);
  Move(R[0], Block[0], 4);
  Move(L[0], Block[4], 4);

  // Обратная перестановка
  Result := Permute(Block, FP, 64, 64);

  // DESX: XOR с K3
  Result := XORBytes(Result, FKey3);
end;

function TDESX.DecryptBlock(const Data: array of Byte): TByteArray;
var
  Block: TByteArray;
  L, R, Temp: TByteArray;
  Round: Integer;
begin
  SetLength(Block, 8);
  Move(Data[0], Block[0], Min(8, Length(Data)));

  // DESX: XOR с K3
  Block := XORBytes(Block, FKey3);

  // Начальная перестановка
  Block := Permute(Block, IP, 64, 64);

  // Разделение
  SetLength(L, 4);
  SetLength(R, 4);
  Move(Block[0], L[0], 4);
  Move(Block[4], R[0], 4);

  // 16 раундов в обратном порядке
  for Round := 15 downto 0 do
  begin
    Temp := R;
    R := L;
    L := XORBytes(Temp, Feistel(L, FSubKeys[Round]));
  end;

  // Объединение
  SetLength(Block, 8);
  Move(L[0], Block[0], 4);
  Move(R[0], Block[4], 4);

  // Обратная перестановка
  Result := Permute(Block, FP, 64, 64);

  // DESX: XOR с K2
  Result := XORBytes(Result, FKey2);
end;

procedure TDESX.EncryptFile(const InputFile, OutputFile: string);
var
  Input, Output: TFileStream;
  Buffer: array[0..7] of Byte;
  EncryptedBlock: TByteArray;
  BytesRead: Integer;
  Padding: Byte;
begin
  Input := TFileStream.Create(InputFile, fmOpenRead);
  try
    Output := TFileStream.Create(OutputFile, fmCreate);
    try
      repeat
        BytesRead := Input.Read(Buffer, 8);
        if BytesRead > 0 then
        begin
          // Добавляем паддинг для последнего блока
          if BytesRead < 8 then
          begin
            Padding := 8 - BytesRead;
            FillChar(Buffer[BytesRead], Padding, Padding);
          end;

          EncryptedBlock := EncryptBlock(Buffer);
          Output.Write(EncryptedBlock[0], 8);
        end;
      until BytesRead < 8;
    finally
      Output.Free;
    end;
  finally
    Input.Free;
  end;
end;

procedure TDESX.DecryptFile(const InputFile, OutputFile: string);
var
  Input, Output: TFileStream;
  Buffer: array[0..7] of Byte;
  DecryptedBlock: TByteArray;
  BytesRead: Integer;
  Padding: Byte;
begin
  Input := TFileStream.Create(InputFile, fmOpenRead);
  try
    Output := TFileStream.Create(OutputFile, fmCreate);
    try
      repeat
        BytesRead := Input.Read(Buffer, 8);
        if BytesRead = 8 then
        begin
          DecryptedBlock := DecryptBlock(Buffer);

          // Удаляем паддинг из последнего блока
          if Input.Position = Input.Size then
          begin
            Padding := DecryptedBlock[7];
            if Padding <= 8 then
              Output.Write(DecryptedBlock[0], 8 - Padding)
            else
              Output.Write(DecryptedBlock[0], 8);
          end
          else
            Output.Write(DecryptedBlock[0], 8);
        end;
      until BytesRead < 8;
    finally
      Output.Free;
    end;
  finally
    Input.Free;
  end;
end;

end.
