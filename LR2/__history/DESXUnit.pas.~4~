  TDESX = class
  private
    // рЮАКХЖШ ОЕПЕЯРЮМНБНЙ ДКЪ DES
    const
      IP: array[0..63] of Byte = (
        58, 50, 42, 34, 26, 18, 10, 2, 60, 52, 44, 36, 28, 20, 12, 4,
