      );

      // йНКХВЕЯРБН ЯДБХЦНБ ДКЪ ЙЮФДНЦН ПЮСМДЮ
      Shifts: array[0..15] of Byte = (1, 1, 2, 2, 2, 2, 2, 2, 1, 2, 2, 2, 2, 2, 2, 1);

  private
    FKey1: array[0..7] of Byte;  // нЯМНБМНИ ЙКЧВ DES
    FKey2: array[0..7] of Byte;  // бМЕЬМХИ ЙКЧВ XOR (ДКЪ DESX)
    FKey3: array[0..7] of Byte;  // бМЕЬМХИ ЙКЧВ XOR (ДКЪ DESX)
    FSubKeys: array[0..15, 0..5] of Byte;  // оНДЙКЧВХ ДКЪ 16 ПЮСМДНБ

    procedure GenerateSubKeys(const Key: array of Byte);
    function InitialPermutation(const Data: array of Byte): TByteArray;
    function FinalPermutation(const Data: array of Byte): TByteArray;
    function Feistel(const R: array of Byte; const SubKey: array of Byte): TByteArray;
    function XORBytes(const A, B: array of Byte): TByteArray;
    procedure SplitBlock(const Block: array of Byte; var L, R: TByteArray);
    function CombineBlocks(const L, R: array of Byte): TByteArray;

  public
    constructor Create;
    procedure SetKeys(const Key1, Key2, Key3: array of Byte);
    function EncryptBlock(const Block: array of Byte): TByteArray;
    function DecryptBlock(const Block: array of Byte): TByteArray;
    function EncryptString(const Text: string): string;
    function DecryptString(const EncryptedText: string): string;
    function EncryptFile(const InputFile, OutputFile: string): Boolean;
    function DecryptFile(const InputFile, OutputFile: string): Boolean;
  end;

implementation

{ TDESX }

constructor TDESX.Create;
begin
  inherited;
  // хМХЖХЮКХГЮЖХЪ ЙКЧВЕИ МСКЪЛХ
  FillChar(FKey1, SizeOf(FKey1), 0);
  FillChar(FKey2, SizeOf(FKey2), 0);
  FillChar(FKey3, SizeOf(FKey3), 0);
end;

procedure TDESX.SetKeys(const Key1, Key2, Key3: array of Byte);
begin
  // йНОХПСЕЛ ЙКЧВХ (ДНКФМШ АШРЭ ОН 8 АЮИР)
  if Length(Key1) >= 8 then
    Move(Key1[0], FKey1[0], 8);
  if Length(Key2) >= 8 then
    Move(Key2[0], FKey2[0], 8);
  if Length(Key3) >= 8 then
    Move(Key3[0], FKey3[0], 8);

  // цЕМЕПХПСЕЛ ОНДЙКЧВХ ДКЪ НЯМНБМНЦН ЙКЧВЮ
  GenerateSubKeys(FKey1);
end;

procedure TDESX.GenerateSubKeys(const Key: array of Byte);
var
  C, D: array[0..27] of Byte;
  Temp: array[0..55] of Byte;
  i, j, Round: Integer;
begin
  // оПХЛЕМЪЕЛ PC1 Й 64-АХРМНЛС ЙКЧВС ДКЪ ОНКСВЕМХЪ 56 АХР
  for i := 0 to 55 do
  begin
    j := PC1[i] - 1;
    Temp[i] := (Key[j div 8] shr (7 - (j mod 8))) and 1;
  end;

  // пЮГДЕКЪЕЛ МЮ C Х D (ОН 28 АХР)
  for i := 0 to 27 do
  begin
    C[i] := Temp[i];
    D[i] := Temp[i + 28];
  end;

  // цЕМЕПХПСЕЛ 16 ОНДЙКЧВЕИ
  for Round := 0 to 15 do
  begin
    // жХЙКХВЕЯЙХИ ЯДБХЦ C Х D
    for i := 0 to Shifts[Round] - 1 do
    begin
      // яДБХЦ C
      Temp[0] := C[0];
      for j := 0 to 26 do
        C[j] := C[j + 1];
      C[27] := Temp[0];

      // яДБХЦ D
      Temp[0] := D[0];
      for j := 0 to 26 do
        D[j] := D[j + 1];
      D[27] := Temp[0];
    end;

    // нАЗЕДХМЪЕЛ C Х D
    for i := 0 to 27 do
    begin
      Temp[i] := C[i];
      Temp[i + 28] := D[i];
    end;

    // оПХЛЕМЪЕЛ PC2 ДКЪ ОНКСВЕМХЪ 48-АХРМНЦН ОНДЙКЧВЮ
    for i := 0 to 47 do
    begin
      j := PC2[i] - 1;
      FSubKeys[Round, i div 8] :=
        (FSubKeys[Round, i div 8] shl 1) or Temp[j];
    end;
  end;
end;

function TDESX.InitialPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);

  for i := 0 to 63 do
  begin
    j := IP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.FinalPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);

  for i := 0 to 63 do
  begin
    j := FP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.Feistel(const R: array of Byte; const SubKey: array of Byte): TByteArray;
var
  ExpandedR: array[0..5] of Byte;
  XorResult: array[0..5] of Byte;
  SBoxInput: array[0..7] of Byte;
  SBoxOutput: array[0..3] of Byte;
  i, j, Row, Col: Integer;
begin
  SetLength(Result, 4);
  FillChar(Result[0], 4, 0);

  // E-ПЮЯЬХПЕМХЕ Я 32 ДН 48 АХР
  FillChar(ExpandedR, 6, 0);
  for i := 0 to 47 do
  begin
    j := E[i] - 1;
    if ((R[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      ExpandedR[i div 8] := ExpandedR[i div 8] or (1 shl (7 - (i mod 8)));
  end;

  // XOR Я ОНДЙКЧВНЛ
  for i := 0 to 5 do
    XorResult[i] := ExpandedR[i] xor SubKey[i];

  // пЮГАХБЮЕЛ МЮ 8 ЦПСОО ОН 6 АХР
  for i := 0 to 7 do
  begin
    // хГБКЕЙЮЕЛ 6 АХР
    SBoxInput[i] := 0;
    for j := 0 to 5 do
    begin
      SBoxInput[i] := SBoxInput[i] shl 1;
      SBoxInput[i] := SBoxInput[i] or ((XorResult[(i * 6 + j) div 8] shr
        (7 - ((i * 6 + j) mod 8))) and 1);
    end;
  end;

  // оПХЛЕМЪЕЛ S-АКНЙХ
  for i := 0 to 7 do
  begin
    Row := ((SBoxInput[i] shr 5) and 2) or (SBoxInput[i] and 1);
    Col := (SBoxInput[i] shr 1) and 15;

    // оНКСВЮЕЛ 4-АХРМШИ ПЕГСКЭРЮР
    if i < 4 then
      SBoxOutput[i div 2] := SBoxOutput[i div 2] shl 4;

    if i mod 2 = 0 then
      SBoxOutput[i div 2] := SBoxOutput[i div 2] or S[i, Row, Col]
    else
      SBoxOutput[i div 2] := SBoxOutput[i div 2] or (S[i, Row, Col] shl 4);
  end;

  // оПХЛЕМЪЕЛ P-ОЕПЕЯРЮМНБЙС
  for i := 0 to 31 do
  begin
    j := P[i] - 1;
    if ((SBoxOutput[j div 8] shr (j mod 8)) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (i mod 8));
  end;
end;

function TDESX.XORBytes(const A, B: array of Byte): TByteArray;
var
  i, Len: Integer;
begin
  Len := Length(A);
  if Length(B) < Len then
    Len := Length(B);

  SetLength(Result, Len);
  for i := 0 to Len - 1 do
    Result[i] := A[i] xor B[i];
end;

procedure TDESX.SplitBlock(const Block: array of Byte; var L, R: TByteArray);
begin
  SetLength(L, 4);
  SetLength(R, 4);
  Move(Block[0], L[0], 4);
  Move(Block[4], R[0], 4);
end;

function TDESX.CombineBlocks(const L, R: array of Byte): TByteArray;
begin
  SetLength(Result, 8);
  Move(L[0], Result[0], 4);
  Move(R[0], Result[4], 4);
end;

function TDESX.EncryptBlock(const Block: array of Byte): TByteArray;
var
  IPBlock: TByteArray;
  L, R, Temp: TByteArray;
  NewL, NewR: TByteArray;
  i: Integer;
begin
  // DESX: Block XOR Key2
  Temp := XORBytes(Block, FKey2);

  // Initial Permutation
  IPBlock := InitialPermutation(Temp);

  // Split into L and R
  SplitBlock(IPBlock, L, R);

  // 16 rounds
  for i := 0 to 15 do
  begin
    NewL := R;
    NewR := XORBytes(L, Feistel(R, FSubKeys[i]));
    L := NewL;
    R := NewR;
  end;

  // Final Permutation
  Result := FinalPermutation(CombineBlocks(R, L));

  // DESX: Result XOR Key3
  Result := XORBytes(Result, FKey3);
end;

function TDESX.DecryptBlock(const Block: array of Byte): TByteArray;
var
  FPBlock: TByteArray;
  L, R, Temp: TByteArray;
  NewL, NewR: TByteArray;
  i: Integer;
begin
  // DESX: Block XOR Key3
  Temp := XORBytes(Block, FKey3);

  // Initial Permutation (for decryption we use same as encryption but with reversed keys)
  FPBlock := InitialPermutation(Temp);

  // Split into L and R
  SplitBlock(FPBlock, L, R);

  // 16 rounds in reverse order
  for i := 15 downto 0 do
  begin
    NewR := L;
    NewL := XORBytes(R, Feistel(L, FSubKeys[i]));
    L := NewL;
    R := NewR;
  end;

  // Final Permutation
  Result := FinalPermutation(CombineBlocks(L, R));

  // DESX: Result XOR Key2
  Result := XORBytes(Result, FKey2);
end;

function TDESX.EncryptString(const Text: string): string;
var
  InputBytes, OutputBytes: TByteArray;
  i, BlockCount: Integer;
  Block: array[0..7] of Byte;
  EncryptedBlock: TByteArray;
  Utf8Bytes: TBytes;
begin
  // йНМБЕПРХПСЕЛ ЯРПНЙС Б UTF-8 АЮИРШ
  Utf8Bytes := TEncoding.UTF8.GetBytes(Text);
  SetLength(InputBytes, Length(Utf8Bytes));
  Move(Utf8Bytes[0], InputBytes[0], Length(Utf8Bytes));

  // дНАЮБКЪЕЛ ОЮДДХМЦ (PKCS7)
  BlockCount := (Length(InputBytes) + 7) div 8;
  SetLength(InputBytes, BlockCount * 8);
  for i := Length(Utf8Bytes) to Length(InputBytes) - 1 do
    InputBytes[i] := BlockCount * 8 - Length(Utf8Bytes);

  // ьХТПСЕЛ
  SetLength(OutputBytes, Length(InputBytes));
  for i := 0 to BlockCount - 1 do
  begin
    Move(InputBytes[i * 8], Block[0], 8);
    EncryptedBlock := EncryptBlock(Block);
    Move(EncryptedBlock[0], OutputBytes[i * 8], 8);
  end;

  // йНМБЕПРХПСЕЛ Б base64 ЯРПНЙС
  Result := TEncoding.ASCII.GetString(
    TEncoding.Convert(TEncoding.Default, TEncoding.ASCII, OutputBytes)
  );
end;

function TDESX.DecryptString(const EncryptedText: string): string;
var
  InputBytes, OutputBytes: TByteArray;
  i, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  DecryptedBlock: TByteArray;
  Utf8Bytes: TBytes;
begin
  // йНМБЕПРХПСЕЛ ХГ base64
  InputBytes := TEncoding.Convert(TEncoding.ASCII, TEncoding.Default,
    TEncoding.ASCII.GetBytes(EncryptedText));

  BlockCount := Length(InputBytes) div 8;
  SetLength(OutputBytes, Length(InputBytes));

  // дЕЬХТПСЕЛ
  for i := 0 to BlockCount - 1 do
  begin
    Move(InputBytes[i * 8], Block[0], 8);
    DecryptedBlock := DecryptBlock(Block);
    Move(DecryptedBlock[0], OutputBytes[i * 8], 8);
  end;

  // сАХПЮЕЛ ОЮДДХМЦ
  Padding := OutputBytes[Length(OutputBytes) - 1];
  if Padding > 0 then
    SetLength(OutputBytes, Length(OutputBytes) - Padding);

  // йНМБЕПРХПСЕЛ НАПЮРМН Б ЯРПНЙС
  SetLength(Utf8Bytes, Length(OutputBytes));
  Move(OutputBytes[0], Utf8Bytes[0], Length(OutputBytes));
  Result := TEncoding.UTF8.GetString(Utf8Bytes);
end;

function TDESX.EncryptFile(const InputFile, OutputFile: string): Boolean;
var
  InputStream, OutputStream: TFileStream;
  Buffer: array[0..7] of Byte;
  EncryptedBlock: TByteArray;
  FileSize, OriginalSize: Int64;
  BytesRead, Padding, i: Integer;
begin
  Result := False;
  try
    InputStream := TFileStream.Create(InputFile, fmOpenRead);
    try
      OutputStream := TFileStream.Create(OutputFile, fmCreate);
      try
        // яНУПЮМЪЕЛ НПХЦХМЮКЭМШИ ПЮГЛЕП ТЮИКЮ
        OriginalSize := InputStream.Size;
        OutputStream.Write(OriginalSize, SizeOf(OriginalSize));

        // ьХТПСЕЛ ТЮИК
        FileSize := 0;
        while FileSize < OriginalSize do
        begin
          BytesRead := InputStream.Read(Buffer, 8);
          if BytesRead < 8 then
          begin
            // дНАЮБКЪЕЛ ОЮДДХМЦ
            Padding := 8 - BytesRead;
            for i := BytesRead to 7 do
              Buffer[i] := Padding;
          end;

          EncryptedBlock := EncryptBlock(Buffer);
          OutputStream.Write(EncryptedBlock[0], 8);
          Inc(FileSize, 8);
        end;

        Result := True;
      finally
        OutputStream.Free;
      end;
    finally
      InputStream.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

function TDESX.DecryptFile(const InputFile, OutputFile: string): Boolean;
var
  InputStream, OutputStream: TFileStream;
  Buffer: array[0..7] of Byte;
  DecryptedBlock: TByteArray;
  OriginalSize, FileSize: Int64;
  Padding, i: Integer;
begin
  Result := False;
  try
    InputStream := TFileStream.Create(InputFile, fmOpenRead);
    try
      OutputStream := TFileStream.Create(OutputFile, fmCreate);
      try
        // вХРЮЕЛ НПХЦХМЮКЭМШИ ПЮГЛЕП
        InputStream.Read(OriginalSize, SizeOf(OriginalSize));

        // дЕЬХТПСЕЛ ТЮИК
        FileSize := 0;
        while InputStream.Position < InputStream.Size do
        begin
          InputStream.Read(Buffer, 8);
          DecryptedBlock := DecryptBlock(Buffer);

          if InputStream.Position >= InputStream.Size then
          begin
            // оНЯКЕДМХИ АКНЙ, САХПЮЕЛ ОЮДДХМЦ
            Padding := DecryptedBlock[7];
            if Padding > 0 then
              OutputStream.Write(DecryptedBlock[0], 8 - Padding)
            else
              OutputStream.Write(DecryptedBlock[0], 8);
          end
          else
            OutputStream.Write(DecryptedBlock[0], 8);
        end;

        Result := True;
      finally
        OutputStream.Free;
      end;
    finally
      InputStream.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

end.
