unit MainForm;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, StdCtrls, DESXUnit;

type
  TForm1 = class(TForm)
    // Объявление компонентов
    lblKey1: TLabel;
    lblKey2: TLabel;
    lblKey3: TLabel;
    edtKey1: TEdit;
    edtKey2: TEdit;
    edtKey3: TEdit;
    btnGenerateKeys: TButton;
    lblInputFile: TLabel;
    lblOutputFile: TLabel;
    edtInputFile: TEdit;
    edtOutputFile: TEdit;
    btnEncrypt: TButton;
    btnDecrypt: TButton;
    mmoInfo: TMemo;
    OpenDialog: TOpenDialog;
    SaveDialog: TSaveDialog;

    // Обработчики событий
    procedure FormCreate(Sender: TObject);
    procedure btnGenerateKeysClick(Sender: TObject);
    procedure btnSelectInputClick(Sender: TObject);
    procedure btnSelectOutputClick(Sender: TObject);
    procedure btnEncryptClick(Sender: TObject);
    procedure btnDecryptClick(Sender: TObject);

  private
    FDESX: TDESX;
    procedure GenerateRandomKey(var Key: TKeyArray);
    function HexToBytes(const Hex: string): TByteArray;
    function BytesToHex(const Bytes: TByteArray): string;
    procedure UpdateInfo;
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);
begin
  // Генерируем ключи при запуске
  btnGenerateKeys.Click;
end;

procedure TForm1.GenerateRandomKey(var Key: TKeyArray);
var
  i: Integer;
begin
  for i := 0 to 7 do
    Key[i] := Random(256);
end;

function TForm1.BytesToHex(const Bytes: TByteArray): string;
var
  i: Integer;
begin
  Result := '';
  for i := 0 to High(Bytes) do
    Result := Result + IntToHex(Bytes[i], 2);
end;

function TForm1.HexToBytes(const Hex: string): TByteArray;
var
  i: Integer;
  HexStr: string;
begin
  SetLength(Result, 8);
  HexStr := Hex;
  // Дополняем до 16 символов
  while Length(HexStr) < 16 do
    HexStr := '0' + HexStr;

  for i := 0 to 7 do
    Result[i] := StrToInt('$' + Copy(HexStr, i*2 + 1, 2));
end;

procedure TForm1.btnGenerateKeysClick(Sender: TObject);
var
  Key1, Key2, Key3: TKeyArray;
begin
  // Генерируем три случайных ключа
  GenerateRandomKey(Key1);
  GenerateRandomKey(Key2);
  GenerateRandomKey(Key3);

  // Отображаем ключи в шестнадцатеричном формате
  edtKey1.Text := BytesToHex(Key1);
  edtKey2.Text := BytesToHex(Key2);
  edtKey3.Text := BytesToHex(Key3);

  // Создаем объект DESX
  if Assigned(FDESX) then
    FDESX.Free;

  FDESX := TDESX.Create(Key1, Key2, Key3);

  UpdateInfo;
end;

procedure TForm1.btnSelectInputClick(Sender: TObject);
begin
  if OpenDialog.Execute then
    edtInputFile.Text := OpenDialog.FileName;
end;

procedure TForm1.btnSelectOutputClick(Sender: TObject);
begin
  if SaveDialog.Execute then
    edtOutputFile.Text := SaveDialog.FileName;
end;

procedure TForm1.btnEncryptClick(Sender: TObject);
begin
  if edtInputFile.Text = '' then
  begin
    ShowMessage('Выберите входной файл!');
    Exit;
  end;

  if edtOutputFile.Text = '' then
  begin
    ShowMessage('Укажите выходной файл!');
    Exit;
  end;

  if not Assigned(FDESX) then
  begin
    ShowMessage('Сначала сгенерируйте ключи!');
    Exit;
  end;

  try
    Screen.Cursor := crHourGlass;
    FDESX.EncryptFile(edtInputFile.Text, edtOutputFile.Text);
    Screen.Cursor := crDefault;
    ShowMessage('Файл успешно зашифрован!');
    UpdateInfo;
  except
    on E: Exception do
    begin
      Screen.Cursor := crDefault;
      ShowMessage('Ошибка: ' + E.Message);
    end;
  end;
end;

procedure TForm1.btnDecryptClick(Sender: TObject);
begin
  if edtInputFile.Text = '' then
  begin
    ShowMessage('Выберите входной файл!');
    Exit;
  end;

  if edtOutputFile.Text = '' then
  begin
    ShowMessage('Укажите выходной файл!');
    Exit;
  end;

  if not Assigned(FDESX) then
  begin
    ShowMessage('Сначала сгенерируйте ключи!');
    Exit;
  end;

  try
    Screen.Cursor := crHourGlass;
    FDESX.DecryptFile(edtInputFile.Text, edtOutputFile.Text);
    Screen.Cursor := crDefault;
    ShowMessage('Файл успешно расшифрован!');
    UpdateInfo;
  except
    on E: Exception do
    begin
      Screen.Cursor := crDefault;
      ShowMessage('Ошибка: ' + E.Message);
    end;
  end;
end;

procedure TForm1.UpdateInfo;
begin
  mmoInfo.Lines.Clear;
  mmoInfo.Lines.Add('=== DESX Шифратор ===');
  mmoInfo.Lines.Add('');
  mmoInfo.Lines.Add('Ключ 1 (внутренний): ' + edtKey1.Text);
  mmoInfo.Lines.Add('Ключ 2 (внешний): ' + edtKey2.Text);
  mmoInfo.Lines.Add('Ключ 3 (внешний): ' + edtKey3.Text);
  mmoInfo.Lines.Add('');
  mmoInfo.Lines.Add('Длина ключа: 192 бита');
  mmoInfo.Lines.Add('Длина блока: 64 бита');
  mmoInfo.Lines.Add('Режим: ECB с PKCS#7 паддингом');
end;

end.
