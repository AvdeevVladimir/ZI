unit DESXUnit;

interface

uses
  SysUtils, Classes, Windows;

type
  TByteArray = array of Byte;

  TDESX = class
  private
    // Таблицы перестановок для DES
    const
      IP: array[0..63] of Byte = (
        58, 50, 42, 34, 26, 18, 10, 2, 60, 52, 44, 36, 28, 20, 12, 4,
