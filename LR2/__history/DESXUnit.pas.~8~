      E: array[0..47] of Byte = (
        32, 1, 2, 3, 4, 5, 4, 5, 6, 7, 8, 9,
        8, 9, 10, 11, 12, 13, 12, 13, 14, 15, 16, 17,
        16, 17, 18, 19, 20, 21, 20, 21, 22, 23, 24, 25,
        24, 25, 26, 27, 28, 29, 28, 29, 30, 31, 32, 1
      );

      P: array[0..31] of Byte = (
        16, 7, 20, 21, 29, 12, 28, 17, 1, 15, 23, 26, 5, 18, 31, 10,
        2, 8, 24, 14, 32, 27, 3, 9, 19, 13, 30, 6, 22, 11, 4, 25
      );

      PC1: array[0..55] of Byte = (
        57, 49, 41, 33, 25, 17, 9, 1, 58, 50, 42, 34, 26, 18,
        10, 2, 59, 51, 43, 35, 27, 19, 11, 3, 60, 52, 44, 36,
        63, 55, 47, 39, 31, 23, 15, 7, 62, 54, 46, 38, 30, 22,
        14, 6, 61, 53, 45, 37, 29, 21, 13, 5, 28, 20, 12, 4
      );

      PC2: array[0..47] of Byte = (
        14, 17, 11, 24, 1, 5, 3, 28, 15, 6, 21, 10,
        23, 19, 12, 4, 26, 8, 16, 7, 27, 20, 13, 2,
        41, 52, 31, 37, 47, 55, 30, 40, 51, 45, 33, 48,
        44, 49, 39, 56, 34, 53, 46, 42, 50, 36, 29, 32
      );

      // S-блоки
      S: array[0..7, 0..3, 0..15] of Byte = (
        // S1
        ((14,4,13,1,2,15,11,8,3,10,6,12,5,9,0,7),
         (0,15,7,4,14,2,13,1,10,6,12,11,9,5,3,8),
         (4,1,14,8,13,6,2,11,15,12,9,7,3,10,5,0),
         (15,12,8,2,4,9,1,7,5,11,3,14,10,0,6,13)),
        // S2
        ((15,1,8,14,6,11,3,4,9,7,2,13,12,0,5,10),
         (3,13,4,7,15,2,8,14,12,0,1,10,6,9,11,5),
         (0,14,7,11,10,4,13,1,5,8,12,6,9,3,2,15),
         (13,8,10,1,3,15,4,2,11,6,7,12,0,5,14,9)),
        // S3
        ((10,0,9,14,6,3,15,5,1,13,12,7,11,4,2,8),
         (13,7,0,9,3,4,6,10,2,8,5,14,12,11,15,1),
         (13,6,4,9,8,15,3,0,11,1,2,12,5,10,14,7),
         (1,10,13,0,6,9,8,7,4,15,14,3,11,5,2,12)),
        // S4
        ((7,13,14,3,0,6,9,10,1,2,8,5,11,12,4,15),
         (13,8,11,5,6,15,0,3,4,7,2,12,1,10,14,9),
         (10,6,9,0,12,11,7,13,15,1,3,14,5,2,8,4),
         (3,15,0,6,10,1,13,8,9,4,5,11,12,7,2,14)),
        // S5
        ((2,12,4,1,7,10,11,6,8,5,3,15,13,0,14,9),
         (14,11,2,12,4,7,13,1,5,0,15,10,3,9,8,6),
         (4,2,1,11,10,13,7,8,15,9,12,5,6,3,0,14),
         (11,8,12,7,1,14,2,13,6,15,0,9,10,4,5,3)),
        // S6
        ((12,1,10,15,9,2,6,8,0,13,3,4,14,7,5,11),
         (10,15,4,2,7,12,9,5,6,1,13,14,0,11,3,8),
         (9,14,15,5,2,8,12,3,7,0,4,10,1,13,11,6),
         (4,3,2,12,9,5,15,10,11,14,1,7,6,0,8,13)),
        // S7
        ((4,11,2,14,15,0,8,13,3,12,9,7,5,10,6,1),
         (13,0,11,7,4,9,1,10,14,3,5,12,2,15,8,6),
         (1,4,11,13,12,3,7,14,10,15,6,8,0,5,9,2),
         (6,11,13,8,1,4,10,7,9,5,0,15,14,2,3,12)),
        // S8
        ((13,2,8,4,6,15,11,1,10,9,3,14,5,0,12,7),
         (1,15,13,8,10,3,7,4,12,5,6,11,0,14,9,2),
         (7,11,4,1,9,12,14,2,0,6,10,13,15,3,5,8),
         (2,1,14,7,4,10,8,13,15,12,9,0,3,5,6,11))
      );

      // Количество сдвигов для каждого раунда
      Shifts: array[0..15] of Byte = (1, 1, 2, 2, 2, 2, 2, 2, 1, 2, 2, 2, 2, 2, 2, 1);

  private
    FKey1: array[0..7] of Byte;  // Основной ключ DES
    FKey2: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)
    FKey3: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)
    FSubKeys: array[0..15, 0..5] of Byte;  // Подключи для 16 раундов

    procedure GenerateSubKeys(const Key: array of Byte);
    function InitialPermutation(const Data: array of Byte): TByteArray;
    function FinalPermutation(const Data: array of Byte): TByteArray;
    function Feistel(const R: array of Byte; const SubKey: array of Byte): TByteArray;
    function XORBytes(const A, B: array of Byte): TByteArray;
    procedure SplitBlock(const Block: array of Byte; var L, R: TByteArray);
    function CombineBlocks(const L, R: array of Byte): TByteArray;
    function DES_EncryptBlock(const Block: array of Byte): TByteArray;
    function DES_DecryptBlock(const Block: array of Byte): TByteArray;

  public
    constructor Create;
    procedure SetKeys(const Key1, Key2, Key3: array of Byte);
    function EncryptString(const Text: string): string;
    function DecryptString(const EncryptedText: string): string;
    function EncryptFile(const InputFile, OutputFile: string): Boolean;
    function DecryptFile(const InputFile, OutputFile: string): Boolean;
  end;

implementation

{ TDESX }

constructor TDESX.Create;
begin
  inherited;
  FillChar(FKey1, SizeOf(FKey1), 0);
  FillChar(FKey2, SizeOf(FKey2), 0);
  FillChar(FKey3, SizeOf(FKey3), 0);
end;

procedure TDESX.SetKeys(const Key1, Key2, Key3: array of Byte);
begin
  if Length(Key1) >= 8 then Move(Key1[0], FKey1[0], 8);
  if Length(Key2) >= 8 then Move(Key2[0], FKey2[0], 8);
  if Length(Key3) >= 8 then Move(Key3[0], FKey3[0], 8);
  GenerateSubKeys(FKey1);
end;

procedure TDESX.GenerateSubKeys(const Key: array of Byte);
var
  C, D: array[0..27] of Byte;
  Temp: array[0..55] of Byte;
  i, j, Round: Integer;
begin
  for i := 0 to 55 do
  begin
    j := PC1[i] - 1;
    Temp[i] := (Key[j div 8] shr (7 - (j mod 8))) and 1;
  end;

  for i := 0 to 27 do
  begin
    C[i] := Temp[i];
    D[i] := Temp[i + 28];
  end;

  for Round := 0 to 15 do
  begin
    for i := 0 to Shifts[Round] - 1 do
    begin
      Temp[0] := C[0];
      for j := 0 to 26 do C[j] := C[j + 1];
      C[27] := Temp[0];

      Temp[0] := D[0];
      for j := 0 to 26 do D[j] := D[j + 1];
      D[27] := Temp[0];
    end;

    for i := 0 to 27 do
    begin
      Temp[i] := C[i];
      Temp[i + 28] := D[i];
    end;

    for i := 0 to 47 do
    begin
      j := PC2[i] - 1;
      FSubKeys[Round, i div 8] := (FSubKeys[Round, i div 8] shl 1) or Temp[j];
    end;
  end;
end;

function TDESX.InitialPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);
  for i := 0 to 63 do
  begin
    j := IP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.FinalPermutation(const Data: array of Byte): TByteArray;
var
  i, j: Integer;
begin
  SetLength(Result, 8);
  FillChar(Result[0], 8, 0);
  for i := 0 to 63 do
  begin
    j := FP[i] - 1;
    if ((Data[j div 8] shr (7 - (j mod 8))) and 1) = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (7 - (i mod 8)));
  end;
end;

function TDESX.Feistel(const R: array of Byte; const SubKey: array of Byte): TByteArray;
var
  ExpandedR: array[0..5] of Byte;
  XorResult: array[0..5] of Byte;
  SBoxInput: array[0..7] of Byte;
  SBoxOutput: array[0..3] of Byte;
  i, j, Row, Col: Integer;
  bit: Byte;
begin
  SetLength(Result, 4);
  FillChar(Result[0], 4, 0);

  FillChar(ExpandedR, 6, 0);
  for i := 0 to 47 do
  begin
    j := E[i] - 1;
    bit := (R[j div 8] shr (7 - (j mod 8))) and 1;
    if bit = 1 then
      ExpandedR[i div 8] := ExpandedR[i div 8] or (1 shl (7 - (i mod 8)));
  end;

  for i := 0 to 5 do
    XorResult[i] := ExpandedR[i] xor SubKey[i];

  for i := 0 to 7 do
  begin
    SBoxInput[i] := 0;
    for j := 0 to 5 do
    begin
      SBoxInput[i] := SBoxInput[i] shl 1;
      bit := (XorResult[(i * 6 + j) div 8] shr (7 - ((i * 6 + j) mod 8))) and 1;
      SBoxInput[i] := SBoxInput[i] or bit;
    end;

    Row := ((SBoxInput[i] shr 5) and 2) or (SBoxInput[i] and 1);
    Col := (SBoxInput[i] shr 1) and 15;

    if i < 4 then
      SBoxOutput[i div 2] := SBoxOutput[i div 2] shl 4;

    if i mod 2 = 0 then
      SBoxOutput[i div 2] := SBoxOutput[i div 2] or S[i, Row, Col]
    else
      SBoxOutput[i div 2] := SBoxOutput[i div 2] or (S[i, Row, Col] shl 4);
  end;

  for i := 0 to 31 do
  begin
    j := P[i] - 1;
    bit := (SBoxOutput[j div 8] shr (j mod 8)) and 1;
    if bit = 1 then
      Result[i div 8] := Result[i div 8] or (1 shl (i mod 8));
  end;
end;

function TDESX.XORBytes(const A, B: array of Byte): TByteArray;
var
  i, Len: Integer;
begin
  Len := Length(A);
  if Length(B) < Len then Len := Length(B);
  SetLength(Result, Len);
  for i := 0 to Len - 1 do Result[i] := A[i] xor B[i];
end;

procedure TDESX.SplitBlock(const Block: array of Byte; var L, R: TByteArray);
begin
  SetLength(L, 4);
  SetLength(R, 4);
  Move(Block[0], L[0], 4);
  Move(Block[4], R[0], 4);
end;

function TDESX.CombineBlocks(const L, R: array of Byte): TByteArray;
begin
  SetLength(Result, 8);
  Move(L[0], Result[0], 4);
  Move(R[0], Result[4], 4);
end;

function TDESX.DES_EncryptBlock(const Block: array of Byte): TByteArray;
var
  IPBlock: TByteArray;
  L, R, NewL, NewR: TByteArray;
  i: Integer;
begin
  IPBlock := InitialPermutation(Block);
  SplitBlock(IPBlock, L, R);

  for i := 0 to 15 do
  begin
    NewL := R;
    NewR := XORBytes(L, Feistel(R, FSubKeys[i]));
    L := NewL;
    R := NewR;
  end;

  Result := FinalPermutation(CombineBlocks(R, L));
end;

function TDESX.DES_DecryptBlock(const Block: array of Byte): TByteArray;
var
  FPBlock: TByteArray;
  L, R, NewL, NewR: TByteArray;
  i: Integer;
begin
  FPBlock := InitialPermutation(Block);
  SplitBlock(FPBlock, L, R);

  for i := 15 downto 0 do
  begin
    NewR := L;
    NewL := XORBytes(R, Feistel(L, FSubKeys[i]));
    L := NewL;
    R := NewR;
  end;

  Result := FinalPermutation(CombineBlocks(L, R));
end;

// Функция для преобразования строки в байты (ANSI)
function StringToBytes(const S: string): TByteArray;
var
  AnsiStr: AnsiString;
  i: Integer;
begin
  AnsiStr := AnsiString(S);
  SetLength(Result, Length(AnsiStr));
  for i := 0 to Length(AnsiStr) - 1 do
    Result[i] := Byte(AnsiStr[i+1]);
end;

// Функция для преобразования байт в строку (ANSI)
function BytesToString(const Bytes: TByteArray): string;
var
  AnsiStr: AnsiString;
  i: Integer;
begin
  SetLength(AnsiStr, Length(Bytes));
  for i := 0 to Length(Bytes) - 1 do
    AnsiStr[i+1] := AnsiChar(Bytes[i]);
  Result := string(AnsiStr);
end;

// Функция для отладки - показывает байты в читаемом виде
function DebugBytes(const Bytes: TByteArray; const Title: string): string;
var
  i: Integer;
begin
  Result := Title + ': ';
  for i := 0 to Length(Bytes) - 1 do
    Result := Result + IntToHex(Bytes[i], 2) + ' ';
end;

// НАСТОЯЩИЙ DESX
function TDESX.EncryptString(const Text: string): string;
var
  Bytes, TempBytes, EncryptedBytes: TByteArray;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  DesResult: TByteArray;
begin
  try
    Result := '';

    // 1. Преобразуем строку в ANSI байты
    Bytes := StringToBytes(Text);

    // 2. Добавляем паддинг (PKCS7)
    Padding := 8 - (Length(Bytes) mod 8);
    if Padding = 8 then Padding := 0;

    if Padding > 0 then
    begin
      SetLength(TempBytes, Length(Bytes) + Padding);
      Move(Bytes[0], TempBytes[0], Length(Bytes));
      for i := 0 to Padding - 1 do
        TempBytes[Length(Bytes) + i] := Padding;
      Bytes := TempBytes;
    end;

    // 3. DESX шифрование
    BlockCount := Length(Bytes) div 8;
    SetLength(EncryptedBytes, Length(Bytes));

    for i := 0 to BlockCount - 1 do
    begin
      Move(Bytes[i * 8], Block[0], 8);

      // XOR с Key2
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey2[j];

      // DES шифрование
      DesResult := DES_EncryptBlock(Block);

      // XOR с Key3
      for j := 0 to 7 do
        DesResult[j] := DesResult[j] xor FKey3[j];

      Move(DesResult[0], EncryptedBytes[i * 8], 8);
    end;

    // 4. В HEX с пробелами
    for i := 0 to Length(EncryptedBytes) - 1 do
    begin
      Result := Result + IntToHex(EncryptedBytes[i], 2);
      if (i + 1) mod 4 = 0 then
        Result := Result + ' ';
      if (i + 1) mod 16 = 0 then
        Result := Result + #13#10;
    end;

  except
    on E: Exception do
      Result := 'Error';
  end;
end;

// НАСТОЯЩИЙ DESX - РАСШИФРОВКА
function TDESX.DecryptString(const EncryptedText: string): string;
var
  Bytes, DecryptedBytes: TByteArray;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  DesResult: TByteArray;
  HexStr: string;
begin
  try
    Result := '';

    // 1. Убираем пробелы и переносы
    HexStr := '';
    for i := 1 to Length(EncryptedText) do
    begin
      if EncryptedText[i] in ['0'..'9', 'A'..'F', 'a'..'f'] then
        HexStr := HexStr + EncryptedText[i];
    end;

    if HexStr = '' then Exit;

    // 2. HEX в байты
    SetLength(Bytes, Length(HexStr) div 2);
    for i := 0 to (Length(HexStr) div 2) - 1 do
      Bytes[i] := StrToInt('$' + Copy(HexStr, i*2 + 1, 2));

    // 3. Проверяем, что длина кратна 8
    if Length(Bytes) mod 8 <> 0 then
    begin
      Result := 'Error: Invalid data length';
      Exit;
    end;

    // 4. DESX дешифрование
    BlockCount := Length(Bytes) div 8;
    SetLength(DecryptedBytes, Length(Bytes));

    for i := 0 to BlockCount - 1 do
    begin
      Move(Bytes[i * 8], Block[0], 8);

      // XOR с Key3
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey3[j];

      // DES дешифрование
      DesResult := DES_DecryptBlock(Block);

      // XOR с Key2
      for j := 0 to 7 do
        DesResult[j] := DesResult[j] xor FKey2[j];

      Move(DesResult[0], DecryptedBytes[i * 8], 8);
    end;

    // 5. Убираем паддинг
    if Length(DecryptedBytes) > 0 then
    begin
      Padding := DecryptedBytes[Length(DecryptedBytes) - 1];
      if (Padding > 0) and (Padding <= 8) then
        SetLength(DecryptedBytes, Length(DecryptedBytes) - Padding);
    end;

    // 6. Преобразуем байты обратно в строку
    Result := BytesToString(DecryptedBytes);

  except
    on E: Exception do
      Result := 'Error';
  end;
end;

function TDESX.EncryptFile(const InputFile, OutputFile: string): Boolean;
begin
  Result := False;
  try
    with TStringList.Create do
    try
      LoadFromFile(InputFile);
      with TStringList.Create do
      try
        Text := EncryptString(Text);
        SaveToFile(OutputFile);
      finally
        Free;
      end;
    finally
      Free;
    end;
    Result := True;
  except
    on E: Exception do
      Result := False;
  end;
end;

function TDESX.DecryptFile(const InputFile, OutputFile: string): Boolean;
begin
  Result := False;
  try
    with TStringList.Create do
    try
      LoadFromFile(InputFile);
      with TStringList.Create do
      try
        Text := DecryptString(Text);
        SaveToFile(OutputFile);
      finally
        Free;
      end;
    finally
      Free;
    end;
    Result := True;
  except
    on E: Exception do
      Result := False;
  end;
end;

end.
