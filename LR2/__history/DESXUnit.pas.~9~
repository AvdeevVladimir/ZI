unit DESXUnit;

interface

uses
  SysUtils, Classes, DCPdes, DCPcrypt2;

type
  TByteArray = array of Byte;

  TDESX = class
  private
    FCipher: TDCP_des;  // Используем готовый DES из DCPcrypt
    FKey2: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)
    FKey3: array[0..7] of Byte;  // Внешний ключ XOR (для DESX)

  public
    constructor Create;
    destructor Destroy; override;
    procedure SetKeys(const Key1, Key2, Key3: array of Byte);
    function EncryptString(const Text: string): string;
    function DecryptString(const EncryptedText: string): string;
    function EncryptFile(const InputFile, OutputFile: string): Boolean;
    function DecryptFile(const InputFile, OutputFile: string): Boolean;
  end;

implementation

{ TDESX }

constructor TDESX.Create;
begin
  inherited;
  FCipher := TDCP_des.Create(nil);
  FillChar(FKey2, 8, 0);
  FillChar(FKey3, 8, 0);
end;

destructor TDESX.Destroy;
begin
  FCipher.Free;
  inherited;
end;

procedure TDESX.SetKeys(const Key1, Key2, Key3: array of Byte);
var
  Key: array[0..7] of Byte;
begin
  // Копируем ключи
  Move(Key1[0], Key[0], 8);
  Move(Key2[0], FKey2[0], 8);
  Move(Key3[0], FKey3[0], 8);

  // Устанавливаем ключ для DES
  FCipher.Init(Key, 64, nil);
end;

function TDESX.EncryptString(const Text: string): string;
var
  Bytes, TempBytes, EncryptedBytes: TBytes;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
begin
  try
    Result := '';

    // 1. Преобразуем строку в UTF-8 байты
    Bytes := TEncoding.UTF8.GetBytes(Text);

    // 2. Добавляем паддинг (PKCS7) для кратности 8 байт
    Padding := 8 - (Length(Bytes) mod 8);
    if Padding = 8 then Padding := 0;

    if Padding > 0 then
    begin
      SetLength(TempBytes, Length(Bytes) + Padding);
      Move(Bytes[0], TempBytes[0], Length(Bytes));
      for i := 0 to Padding - 1 do
        TempBytes[Length(Bytes) + i] := Padding;
      Bytes := TempBytes;
    end;

    // 3. DESX шифрование: C = K3 XOR DES(K1 XOR M)
    BlockCount := Length(Bytes) div 8;
    SetLength(EncryptedBytes, Length(Bytes));

    for i := 0 to BlockCount - 1 do
    begin
      // Берем блок
      Move(Bytes[i * 8], Block[0], 8);

      // XOR с Key2 (отбеливание перед DES)
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey2[j];

      // DES шифрование (используем готовую библиотеку)
      FCipher.EncryptECB(Block, Block);

      // XOR с Key3 (отбеливание после DES)
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey3[j];

      Move(Block[0], EncryptedBytes[i * 8], 8);
    end;

    // 4. В HEX с пробелами
    for i := 0 to Length(EncryptedBytes) - 1 do
    begin
      Result := Result + IntToHex(EncryptedBytes[i], 2);
      if (i + 1) mod 4 = 0 then
        Result := Result + ' ';
      if (i + 1) mod 16 = 0 then
        Result := Result + #13#10;
    end;

  except
    on E: Exception do
      Result := 'Error: ' + E.Message;
  end;
end;

function TDESX.DecryptString(const EncryptedText: string): string;
var
  Bytes, DecryptedBytes: TBytes;
  i, j, BlockCount, Padding: Integer;
  Block: array[0..7] of Byte;
  HexStr: string;
begin
  try
    Result := '';

    // 1. Убираем пробелы
    HexStr := '';
    for i := 1 to Length(EncryptedText) do
    begin
      if CharInSet(EncryptedText[i], ['0'..'9', 'A'..'F', 'a'..'f']) then
        HexStr := HexStr + EncryptedText[i];
    end;

    if HexStr = '' then Exit;

    // 2. HEX в байты
    SetLength(Bytes, Length(HexStr) div 2);
    for i := 0 to (Length(HexStr) div 2) - 1 do
      Bytes[i] := StrToInt('$' + Copy(HexStr, i*2 + 1, 2));

    // 3. DESX дешифрование: M = K1 XOR DES-1(K3 XOR C)
    BlockCount := Length(Bytes) div 8;
    SetLength(DecryptedBytes, Length(Bytes));

    for i := 0 to BlockCount - 1 do
    begin
      // Берем блок
      Move(Bytes[i * 8], Block[0], 8);

      // XOR с Key3
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey3[j];

      // DES дешифрование
      FCipher.DecryptECB(Block, Block);

      // XOR с Key2
      for j := 0 to 7 do
        Block[j] := Block[j] xor FKey2[j];

      Move(Block[0], DecryptedBytes[i * 8], 8);
    end;

    // 4. Убираем паддинг
    if Length(DecryptedBytes) > 0 then
    begin
      Padding := DecryptedBytes[Length(DecryptedBytes) - 1];
      if (Padding > 0) and (Padding <= 8) then
        SetLength(DecryptedBytes, Length(DecryptedBytes) - Padding);
    end;

    // 5. Преобразуем байты обратно в текст
    if Length(DecryptedBytes) > 0 then
      Result := TEncoding.UTF8.GetString(DecryptedBytes);

  except
    on E: Exception do
      Result := '';
  end;
end;

function TDESX.EncryptFile(const InputFile, OutputFile: string): Boolean;
var
  SL: TStringList;
begin
  Result := False;
  try
    SL := TStringList.Create;
    try
      SL.LoadFromFile(InputFile);
      SL.Text := EncryptString(SL.Text);
      SL.SaveToFile(OutputFile);
      Result := True;
    finally
      SL.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

function TDESX.DecryptFile(const InputFile, OutputFile: string): Boolean;
var
  SL: TStringList;
begin
  Result := False;
  try
    SL := TStringList.Create;
    try
      SL.LoadFromFile(InputFile);
      SL.Text := DecryptString(SL.Text);
      SL.SaveToFile(OutputFile);
      Result := True;
    finally
      SL.Free;
    end;
  except
    on E: Exception do
      Result := False;
  end;
end;

end.
